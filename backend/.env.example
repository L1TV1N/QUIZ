# Backend Configuration Example
# Скопируйте как .env и заполните реальные значения

# 📱 Telegram Bot Settings
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# 🤖 GigaChat AI Settings (Yandex)
AI_PROVIDER=gigachat
GIGACHAT_AUTH_KEY=your_auth_key_here
GIGACHAT_CLIENT_SECRET=your_client_secret_here

# 💾 Database
DATABASE_URL=sqlite:///database.db

# Инструкция:
# 1. Получите Chat ID: откройте https://api.telegram.org/botTOKEN/getUpdates
# 2. Найдите chat → id
# 3. Вставьте это число в TELEGRAM_CHAT_ID
# 4. GigaChat ключи уже настроены, просто используйте их значения из инструкции
# 5. Перезагрузите backend
